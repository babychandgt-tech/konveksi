{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && BASE_PATH=/ pnpm --filter @workspace/vanny-konveksi run build"
  },
  "deploy": {
    "startCommand": "BASE_PATH=/ pnpm --filter @workspace/vanny-konveksi run serve",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
