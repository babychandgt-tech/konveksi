{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        { "cmd": "pnpm install --no-frozen-lockfile" }
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        { "cmd": "pnpm run build:railway" }
      ]
    }
  },
  "deploy": {
    "startCommand": "pnpm run start"
  }
}
