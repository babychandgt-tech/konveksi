# ─────────────────────────────────────────────────────────────
# Frontend — artifacts/vanny-konveksi
# Set these as Railway environment variables for the web service
# ─────────────────────────────────────────────────────────────

# Auto-provided by Railway — do NOT set manually
# PORT=

# Must be set to "/" for root-mounted deployments
BASE_PATH=/

# Supabase credentials (get from your Supabase project dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─────────────────────────────────────────────────────────────
# API Server — artifacts/api-server
# Set these as Railway environment variables for the api service
# ─────────────────────────────────────────────────────────────

# Auto-provided by Railway — do NOT set manually
# PORT=

# PostgreSQL connection string (add a Railway Postgres plugin
# and this is set automatically via ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgresql://user:password@host:5432/dbname
