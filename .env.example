# ─────────────────────────────────────────────────────────────────────────────
# Vanny Konveksi — Environment Variables
# Deploy as a SINGLE Railway service using artifacts/api-server/railway.json
# ─────────────────────────────────────────────────────────────────────────────

# Auto-provided by Railway — do NOT set manually
# PORT=

# Required: must be "/" for root-mounted deployment
BASE_PATH=/

# Required: Supabase credentials (from your Supabase project dashboard)
# These are embedded into the frontend at BUILD time by Vite
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Midtrans payment gateway (sandbox → production key when live)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx

# Optional: public URL of this deployment (used in Midtrans payment callbacks)
APP_URL=https://your-app.up.railway.app
